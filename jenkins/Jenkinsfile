pipeline {
    agent any

    environment {
        GROQ_API_KEY    = credentials('groq-api-key')
        AWS_ACCESS_KEY  = credentials('aws-access-key')
        AWS_SECRET_KEY  = credentials('aws-secret-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Stage 1: Pulling Code from GitHub =========='
                git credentialsId: 'github-credentials',
                    url: 'https://github.com/CoderSanku/DevSecOps-Assignment.git',
                    branch: 'main'
            }
        }

        stage('Install Tools') {
            steps {
                echo '========== Stage 2: Installing Trivy & Terraform =========='
                sh '''
                    apt-get update -y -qq
                    apt-get install -y wget apt-transport-https gnupg python3 curl unzip

                    wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor > /usr/share/keyrings/trivy.gpg
                    echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" > /etc/apt/sources.list.d/trivy.list
                    apt-get update -qq
                    apt-get install -y trivy
                    trivy --version

                    if ! command -v terraform &> /dev/null; then
                        echo "Installing Terraform..."
                        wget --tries=3 -O /tmp/terraform.zip https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_linux_amd64.zip
                        cd /tmp && unzip -o terraform.zip
                        mv /tmp/terraform /usr/local/bin/terraform
                        chmod +x /usr/local/bin/terraform
                        rm -f /tmp/terraform.zip
                        cd -
                    fi
                    terraform --version
                '''
            }
        }

        stage('Trivy IaC Scan') {
            steps {
                echo '========== Stage 3: Scanning Terraform for Vulnerabilities =========='
                sh '''
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format json \
                        --output trivy-report.json \
                        ./terraform

                    echo "================================================================"
                    echo "           SECURITY VULNERABILITY REPORT"
                    echo "================================================================"
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================================"

                    VULN_COUNT=$(cat trivy-report.json | jq '[.Results[]? | .Misconfigurations[]?] | length')
                    echo "Total vulnerabilities found: $VULN_COUNT"
                    echo "$VULN_COUNT" > /tmp/vuln_count.txt
                '''
            }
        }

        stage('Human Approval: Send to AI?') {
            when {
                expression {
                    def count = sh(script: 'cat /tmp/vuln_count.txt', returnStdout: true).trim()
                    return count != '0'
                }
            }
            steps {
                echo '========== Stage 4: Waiting for Human Review =========='
                echo 'Review the vulnerability report in Stage 3 above.'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Vulnerabilities found! Send the report to Groq AI for automatic fix?', ok: 'Yes, Send to AI'
                }
            }
        }

        stage('AI Security Remediation') {
            when {
                expression {
                    def count = sh(script: 'cat /tmp/vuln_count.txt', returnStdout: true).trim()
                    return count != '0'
                }
            }
            steps {
                echo '========== Stage 5: Groq AI Fixing Vulnerabilities =========='
                sh 'echo "${GROQ_API_KEY}" > /tmp/groq_key.txt'
                writeFile file: '/tmp/fix.py', text: '''
import subprocess, json, urllib.request

result = subprocess.run(
    ["jq", "-r", ".Results[]? | .Misconfigurations[]? | \\"ID: \\" + .ID + \\" | Severity: \\" + .Severity + \\" | Title: \\" + .Title + \\" | Fix: \\" + .Resolution"],
    stdin=open("trivy-report.json"),
    capture_output=True, text=True
)
summary = result.stdout.strip()
print("Vulnerabilities to fix:")
print(summary)

main_tf = open("terraform/main.tf").read()

instructions = (
    "You are fixing a Terraform file. Vulnerabilities found by Trivy:\\n\\n"
    + summary
    + "\\n\\nCurrent terraform/main.tf:\\n\\n"
    + main_tf
    + "\\n\\nCRITICAL INSTRUCTIONS:\\n"
    + "1. Return ONLY valid Terraform HCL code\\n"
    + "2. Do NOT include markdown, backticks, or explanations\\n"
    + "3. Output must start with: terraform {\\n"
    + "4. Fix: SSH cidr to 10.0.0.0/16, app port cidr to 10.0.0.0/16, egress cidr to 10.0.0.0/16, http_tokens to required, encrypted to true, map_public_ip_on_launch to false"
)

payload = json.dumps({
    "model": "llama-3.3-70b-versatile",
    "messages": [
        {
            "role": "system",
            "content": "You are a Terraform security expert. Output ONLY raw Terraform HCL. No markdown. No backticks. No explanations. Start directly with: terraform {"
        },
        {"role": "user", "content": instructions}
    ],
    "temperature": 0.1,
    "max_tokens": 4000
}).encode("utf-8")

api_key = open("/tmp/groq_key.txt").read().strip()
print("Calling Groq API...")

req = urllib.request.Request(
    "https://api.groq.com/openai/v1/chat/completions",
    data=payload,
    headers={"Authorization": "Bearer " + api_key, "Content-Type": "application/json"}
)

try:
    with urllib.request.urlopen(req, timeout=60) as response:
        result = json.loads(response.read().decode("utf-8"))
except urllib.error.HTTPError as e:
    print("HTTP Error: " + str(e.code))
    print(e.read().decode("utf-8"))
    raise

fixed_code = result["choices"][0]["message"]["content"].strip()

# Strip markdown backticks if Groq added them anyway
if fixed_code.startswith("```"):
    lines = fixed_code.splitlines()
    lines = lines[1:]
    if lines and lines[-1].strip() == "```":
        lines = lines[:-1]
    fixed_code = "\\n".join(lines).strip()

# Trim anything before terraform {
if not fixed_code.startswith("terraform {") and "terraform {" in fixed_code:
    fixed_code = fixed_code[fixed_code.index("terraform {"):]

print("AI fix received!")
open("/tmp/ai_fixed_main.tf", "w").write(fixed_code)

print("=" * 64)
print("           AI FIXED TERRAFORM CODE")
print("=" * 64)
print(fixed_code)
print("=" * 64)
'''
                sh '''
                    python3 /tmp/fix.py
                    rm -f /tmp/groq_key.txt
                '''
            }
        }

        stage('Human Approval: Apply Fix?') {
            when {
                expression {
                    def count = sh(script: 'cat /tmp/vuln_count.txt', returnStdout: true).trim()
                    return count != '0'
                }
            }
            steps {
                echo '========== Stage 6: Review AI Fix =========='
                echo 'The AI fixed code has been printed in Stage 5 above.'
                echo 'Review it carefully before applying.'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Apply the AI fixes to terraform/main.tf?', ok: 'Yes, Apply Fix'
                }
                sh '''
                    cp terraform/main.tf terraform/main.tf.backup
                    cp /tmp/ai_fixed_main.tf terraform/main.tf
                    echo "AI fix applied to terraform/main.tf!"
                    echo "Original backed up to terraform/main.tf.backup"
                    echo "New file contents:"
                    cat terraform/main.tf
                '''
            }
        }

        stage('Trivy Re-Scan') {
            when {
                expression {
                    def count = sh(script: 'cat /tmp/vuln_count.txt', returnStdout: true).trim()
                    return count != '0'
                }
            }
            steps {
                echo '========== Stage 7: Re-scanning After AI Fix =========='
                sh '''
                    echo "================================================================"
                    echo "           POST-FIX SECURITY SCAN RESULTS"
                    echo "================================================================"
                    trivy config \
                        --exit-code 1 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================================"
                    echo "ZERO vulnerabilities confirmed - safe to deploy!"
                    echo "================================================================"
                '''
            }
            post {
                success { echo 'SUCCESS: Zero HIGH/CRITICAL vulnerabilities after AI fix!' }
                failure { echo 'WARNING: Some vulnerabilities remain - review AI fix!' }
            }
        }

        stage('Push Fixed Code to GitHub') {
            when {
                expression {
                    def count = sh(script: 'cat /tmp/vuln_count.txt', returnStdout: true).trim()
                    return count != '0'
                }
            }
            steps {
                echo '========== Stage 8: Pushing Fixed Code to GitHub =========='
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                        git config user.email "jenkins@devsecops.com"
                        git config user.name "Jenkins AI Bot"
                        git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@github.com/CoderSanku/DevSecOps-Assignment.git
                        git add terraform/main.tf
                        git commit -m "AI Security Fix: Resolved all Terraform vulnerabilities via Groq AI"
                        git push origin main
                        echo "Fixed code pushed to GitHub successfully!"
                    '''
                }
            }
        }

        stage('Human Approval: Deploy to AWS?') {
            steps {
                echo '========== Stage 9: Ready for AWS Deployment =========='
                echo 'All security checks passed! Infrastructure code is secure.'
                echo 'Terraform will provision the following on AWS ap-south-1:'
                echo '  - VPC + Subnet + Internet Gateway'
                echo '  - Security Group (restricted)'
                echo '  - EC2 t2.micro instance'
                echo '  - Encrypted root volume'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'All security checks passed! Deploy secure infrastructure to AWS?', ok: 'Yes, Deploy to AWS!'
                }
            }
        }

        stage('Terraform Apply - Deploy to AWS') {
            steps {
                echo '========== Stage 10: Deploying to AWS with Terraform =========='
                sh '''
                    export AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY}
                    export AWS_SECRET_ACCESS_KEY=${AWS_SECRET_KEY}
                    export AWS_DEFAULT_REGION=ap-south-1

                    cd terraform

                    echo "Running terraform init..."
                    terraform init -input=false

                    echo "Running terraform plan..."
                    terraform plan -input=false

                    echo "Running terraform apply..."
                    terraform apply -auto-approve -input=false

                    echo "================================================================"
                    echo "           DEPLOYMENT COMPLETE!"
                    echo "================================================================"
                    terraform output
                    echo "================================================================"
                '''
            }
        }

    }

    post {
        always  { echo '========== Pipeline Complete ==========' }
        failure { echo 'Pipeline FAILED - Review the failing stage above.' }
        success { echo 'Pipeline PASSED - App is LIVE on AWS!' }
    }
}
