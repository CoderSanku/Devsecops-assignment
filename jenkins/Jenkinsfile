stage('AI Auto-Fix') {
    environment {
        GROQ_API_KEY = credentials('groq-api-key')
    }
    steps {
        echo '========== Stage 3: Sending Report to Groq AI for Auto-Fix =========='
        sh '''
            SUMMARY=$(cat trivy-report.json | jq -r '
                .Results[]? |
                .Misconfigurations[]? |
                "ID: " + .ID + " | Severity: " + .Severity + " | Fix: " + .Resolution
            ')

            MAIN_TF=$(cat terraform/main.tf)

            cat > /tmp/prompt.json << PROMPTEOF
{
  "model": "llama-3.3-70b-versatile",
  "messages": [
    {
      "role": "system",
      "content": "You are a DevSecOps expert. When given Terraform code and security vulnerabilities, you return ONLY the fixed terraform code. No explanation, no markdown, no backticks. Raw HCL only."
    },
    {
      "role": "user",
      "content": "Fix these Terraform vulnerabilities:\n\n${SUMMARY}\n\nTerraform code to fix:\n\n${MAIN_TF}\n\nReturn ONLY the fixed terraform code starting with: terraform {"
    }
  ],
  "temperature": 0.1,
  "max_tokens": 4000
}
PROMPTEOF

            echo "Calling Groq API..."
            RESPONSE=$(curl -s \
                "https://api.groq.com/openai/v1/chat/completions" \
                -H "Authorization: Bearer ${GROQ_API_KEY}" \
                -H "Content-Type: application/json" \
                -d @/tmp/prompt.json)

            echo "API Status: $(echo $RESPONSE | jq -r '.error.message // "OK"')"

            FIXED_CODE=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // empty')

            if [ -z "$FIXED_CODE" ]; then
                echo "ERROR: AI fix failed!"
                echo "Response: $RESPONSE"
                exit 1
            fi

            echo "$FIXED_CODE" > terraform/main.tf
            echo "Groq AI successfully fixed the Terraform code!"
            cat terraform/main.tf
        '''
    }
}
