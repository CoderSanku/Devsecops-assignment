pipeline {
    agent any

    environment {
        GROQ_API_KEY = credentials('groq-api-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Stage 1: Pulling Code from GitHub =========='
                git credentialsId: 'github-credentials',
                    url: 'https://github.com/CoderSanku/DevSecOps-Assignment.git',
                    branch: 'main'
            }
        }

        stage('Install Tools') {
            steps {
                echo '========== Stage 2: Installing Trivy =========='
                sh '''
                    apt-get update -y -qq
                    apt-get install -y wget apt-transport-https gnupg python3 curl unzip
                    wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor > /usr/share/keyrings/trivy.gpg
                    echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" > /etc/apt/sources.list.d/trivy.list
                    apt-get update -qq
                    apt-get install -y trivy
                    trivy --version

                    if ! command -v terraform &> /dev/null; then
                        echo "Installing Terraform..."
                        wget --tries=3 -O /tmp/terraform.zip https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_linux_amd64.zip
                        cd /tmp && unzip -o terraform.zip
                        mv /tmp/terraform /usr/local/bin/terraform
                        chmod +x /usr/local/bin/terraform
                        rm -f /tmp/terraform.zip
                        cd -
                    fi
                    terraform --version
                '''
            }
        }

        stage('Trivy IaC Scan') {
            steps {
                echo '========== Stage 3: Scanning Terraform for Vulnerabilities =========='
                sh '''
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format json \
                        --output trivy-report.json \
                        ./terraform

                    echo "================================================================"
                    echo "           SECURITY VULNERABILITY REPORT"
                    echo "================================================================"
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================================"
                '''
            }
        }

        stage('Human Approval: Send to AI?') {
            steps {
                echo '========== Stage 4: Waiting for Human Review =========='
                echo 'Review the vulnerability report in Stage 3 above.'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Vulnerabilities found. Send to Groq AI for fix?', ok: 'Yes, Send to AI'
                }
            }
        }

        stage('AI Security Remediation') {
            steps {
                echo '========== Stage 5: Groq AI Fixing Vulnerabilities =========='
                sh '''
                    cat > /tmp/fix.py << 'PYEOF'
import subprocess, json, urllib.request

result = subprocess.run(
    ['jq', '-r', '.Results[]? | .Misconfigurations[]? | "ID: " + .ID + " | Severity: " + .Severity + " | Fix: " + .Resolution'],
    stdin=open('trivy-report.json'),
    capture_output=True, text=True
)
summary = result.stdout.strip()
print('Vulnerabilities found:')
print(summary)

main_tf = open('terraform/main.tf').read()
user_msg = "Fix these Terraform vulnerabilities:\\n\\n" + summary + "\\n\\nTerraform code:\\n\\n" + main_tf + "\\n\\nIMPORTANT: Return ONLY the fixed terraform HCL code. Do NOT add any new resources. Do NOT use variables for cidr_blocks values. Only fix the existing resources listed above."

payload = json.dumps({
    "model": "llama-3.3-70b-versatile",
    "messages": [
        {
            "role": "system",
            "content": "You are a Terraform security expert. Fix ONLY the vulnerabilities mentioned. Do NOT add new resources like NAT gateway, KMS key, private subnet, EIP, or extra route tables. Do NOT use variables like var.something for IP addresses - use actual CIDR strings like 10.0.1.0/24. Keep port 3000 open to 0.0.0.0/0. Return ONLY raw HCL terraform code with no markdown formatting."
        },
        {
            "role": "user",
            "content": user_msg
        }
    ],
    "temperature": 0.1,
    "max_tokens": 4000
}).encode('utf-8')

api_key = open('/tmp/groq_key.txt').read().strip()
print('API key loaded, length: ' + str(len(api_key)))

req = urllib.request.Request(
    'https://api.groq.com/openai/v1/chat/completions',
    data=payload,
    headers={
        'Authorization': 'Bearer ' + api_key,
        'Content-Type': 'application/json',
        'User-Agent': 'Mozilla/5.0'
    }
)

print('Calling Groq API...')
try:
    with urllib.request.urlopen(req, timeout=60) as response:
        result = json.loads(response.read().decode('utf-8'))
except urllib.error.HTTPError as e:
    print('HTTP Error: ' + str(e.code))
    print(e.read().decode('utf-8'))
    raise

fixed_code = result['choices'][0]['message']['content']

fixed_code = fixed_code.replace('```terraform', '')
fixed_code = fixed_code.replace('```hcl', '')
fixed_code = fixed_code.replace('```', '')
fixed_code = fixed_code.replace('var.trusted_ip', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.allowed_cidr', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.my_ip', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.ssh_cidr', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.allowed_ip', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.cidr', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.office_ip', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.admin_ip', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('var.ip', '"10.0.1.0/24"')
fixed_code = fixed_code.replace('192.168.1.0/24', '10.0.1.0/24')
fixed_code = fixed_code.replace('192.168.0.0/16', '10.0.1.0/24')
fixed_code = fixed_code.replace('aws_subnet.private.id', 'aws_subnet.public.id')
fixed_code = fixed_code.strip()

print('AI fix received and cleaned!')

with open('/tmp/ai_fixed_main.tf', 'w') as f:
    f.write(fixed_code)

print('================================================================')
print('           AI FIXED TERRAFORM CODE')
print('================================================================')
print(fixed_code)
print('================================================================')
PYEOF

                    echo "${GROQ_API_KEY}" > /tmp/groq_key.txt
                    python3 /tmp/fix.py
                    rm -f /tmp/groq_key.txt
                '''
            }
        }

        stage('Human Approval: Apply Fix?') {
            steps {
                echo '========== Stage 6: Review AI Fix =========='
                echo 'Review the AI fixed code printed in Stage 5 above.'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Apply AI fixes to terraform/main.tf?', ok: 'Yes, Apply Fix'
                }
                sh '''
                    cp terraform/main.tf terraform/main.tf.backup
                    cp /tmp/ai_fixed_main.tf terraform/main.tf
                    echo "AI fix applied to terraform/main.tf!"
                    echo "Backup saved to terraform/main.tf.backup"
                '''
            }
        }

        stage('Trivy Re-Scan') {
            steps {
                echo '========== Stage 7: Re-scanning After AI Fix =========='
                sh '''
                    echo "================================================================"
                    echo "           POST-FIX SECURITY SCAN RESULTS"
                    echo "================================================================"
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================================"
                '''
            }
            post {
                success { echo 'SUCCESS: Zero HIGH/CRITICAL vulnerabilities!' }
                failure { echo 'WARNING: Vulnerabilities still remain!' }
            }
        }

        stage('Push Fixed Code to GitHub') {
            steps {
                echo '========== Stage 8: Pushing Fixed Code to GitHub =========='
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                        git config user.email "jenkins@devsecops.com"
                        git config user.name "Jenkins AI Bot"
                        git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@github.com/CoderSanku/DevSecOps-Assignment.git
                        git add terraform/main.tf
                        git diff --cached --quiet && echo "No changes to commit" || git commit -m "AI Security Fix: Resolved all Terraform vulnerabilities via Groq AI"
                        git push origin main
                        echo "Fixed code pushed to GitHub successfully!"
                    '''
                }
            }
        }

        stage('Human Approval: Deploy to AWS?') {
            steps {
                echo '========== Stage 9: Ready for AWS Deployment =========='
                echo 'Security scan passed! Infrastructure code is secure.'
                echo 'Terraform will provision the following on AWS ap-south-1:'
                echo '  - VPC + Subnet + Internet Gateway'
                echo '  - Security Group (restricted)'
                echo '  - EC2 t2.micro instance'
                echo '  - Encrypted root volume'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'All security checks passed! Deploy secure infrastructure to AWS?', ok: 'Yes, Deploy to AWS!'
                }
            }
        }

        stage('Terraform Apply - Deploy to AWS') {
            environment {
                AWS_ACCESS_KEY = credentials('aws-access-key')
                AWS_SECRET_KEY = credentials('aws-secret-key')
            }
            steps {
                echo '========== Stage 10: Deploying to AWS with Terraform =========='
                sh '''
                    export AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY}
                    export AWS_SECRET_ACCESS_KEY=${AWS_SECRET_KEY}
                    export AWS_DEFAULT_REGION=ap-south-1

                    cd terraform
                    terraform init -input=false
                    terraform plan -input=false
                    terraform apply -auto-approve -input=false

                    echo "================================================================"
                    echo "           DEPLOYMENT COMPLETE!"
                    echo "================================================================"
                    terraform output
                    echo "================================================================"
                '''
            }
        }

    }

    post {
        always  { echo '========== Pipeline Complete ==========' }
        failure { echo 'Pipeline FAILED - Review the failing stage above.' }
        success { echo 'Pipeline PASSED - App is LIVE on AWS!' }
    }
}
