pipeline {
    agent any

    environment {
        GEMINI_API_KEY = credentials('gemini-api-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Stage 1: Pulling Code from GitHub =========='
                checkout scm
            }
        }

        stage('Install Tools') {
            steps {
                echo '========== Installing Trivy =========='
                sh '''
                    apt-get update -y -qq
                    apt-get install -y wget curl jq
                    curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
                    trivy --version
                '''
            }
        }

        stage('Trivy IaC Scan') {
            steps {
                echo '========== Stage 2: Scanning Terraform for Vulnerabilities =========='
                sh '''
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format json \
                        --output trivy-report.json \
                        ./terraform

                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                '''
            }
        }

        stage('AI Auto-Fix') {
            steps {
                echo '========== Stage 3: Sending Report to Gemini AI for Auto-Fix =========='
                sh '''
                    # Read the trivy report
                    TRIVY_REPORT=$(cat trivy-report.json)
                    MAIN_TF=$(cat terraform/main.tf)

                    # Build prompt for Gemini
                    PROMPT="You are a DevSecOps expert. Here is a Trivy security scan report for Terraform code:\\n\\nTRIVY REPORT:\\n${TRIVY_REPORT}\\n\\nORIGINAL TERRAFORM CODE (main.tf):\\n${MAIN_TF}\\n\\nPlease fix ALL the security vulnerabilities found. Return ONLY the complete fixed main.tf terraform code with no explanation, no markdown, no backticks. Just raw terraform code."

                    # Call Gemini API
                    RESPONSE=$(curl -s \
                        "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_API_KEY}" \
                        -H "Content-Type: application/json" \
                        -d "{
                            \\"contents\\": [{
                                \\"parts\\": [{
                                    \\"text\\": $(echo "$PROMPT" | jq -Rs .)
                                }]
                            }]
                        }")

                    echo "AI Response received"

                    # Extract fixed code from response
                    FIXED_CODE=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text')

                    if [ -z "$FIXED_CODE" ] || [ "$FIXED_CODE" = "null" ]; then
                        echo "❌ AI fix failed - empty response"
                        exit 1
                    fi

                    # Save fixed code
                    echo "$FIXED_CODE" > terraform/main.tf
                    echo "✅ AI has fixed the Terraform code!"
                    echo "========== Fixed Code =========="
                    cat terraform/main.tf
                '''
            }
        }

        stage('Trivy Re-Scan After AI Fix') {
            steps {
                echo '========== Stage 4: Re-scanning After AI Fix =========='
                sh '''
                    trivy config \
                        --exit-code 1 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                '''
            }
            post {
                failure {
                    echo '❌ Still has vulnerabilities after AI fix!'
                }
                success {
                    echo '✅ All vulnerabilities fixed by AI!'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                echo '========== Stage 5: Terraform Plan =========='
                echo 'Security scan passed! Ready for deployment.'
            }
        }

    }

    post {
        always {
            echo '========== Pipeline Complete =========='
        }
        failure {
            echo '❌ Pipeline FAILED'
        }
        success {
            echo '✅ Pipeline PASSED - All security checks cleared!'
        }
    }
}
```

---

## What This Pipeline Does:
```
Stage 1: Checkout        → pulls code from GitHub
Stage 2: Install Tools   → installs Trivy + jq
Stage 3: Trivy Scan      → finds vulnerabilities, saves report
Stage 4: AI Auto-Fix     → sends report to Gemini → gets fixed code
Stage 5: Trivy Re-Scan   → confirms fixes work ✅
Stage 6: Terraform Plan  → ready to deploy
