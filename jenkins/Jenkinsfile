pipeline {
    agent any

    environment {
        GROQ_API_KEY = credentials('groq-api-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Stage 1: Pulling Code from GitHub =========='
                checkout scm
            }
        }

        stage('Install Trivy') {
            steps {
                echo '========== Stage 2: Installing Trivy Scanner =========='
                sh '''
                    apt-get update -y -qq
                    apt-get install -y wget curl jq apt-transport-https gnupg
                    wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor > /usr/share/keyrings/trivy.gpg
                    echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" > /etc/apt/sources.list.d/trivy.list
                    apt-get update -qq
                    apt-get install -y trivy
                    trivy --version
                '''
            }
        }

        stage('Trivy IaC Scan') {
            steps {
                echo '========== Stage 3: Scanning Terraform for Vulnerabilities =========='
                sh '''
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format json \
                        --output trivy-report.json \
                        ./terraform

                    echo ""
                    echo "================================================"
                    echo "         TRIVY SECURITY SCAN REPORT"
                    echo "================================================"
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================"
                    echo "Total vulnerabilities found:"
                    cat trivy-report.json | jq '[.Results[]?.Misconfigurations[]?] | length'
                    echo "================================================"
                '''
            }
        }

        stage('Human Approval: Send to AI?') {
            steps {
                sh '''
                    echo ""
                    echo "================================================"
                    echo "   SECURITY VULNERABILITIES DETECTED!"
                    echo "================================================"
                    cat trivy-report.json | jq -r '
                        .Results[]? |
                        .Misconfigurations[]? |
                        "  ID: " + .ID + " [" + .Severity + "]" + " - " + .Message
                    '
                    echo "================================================"
                    echo "Waiting for human approval..."
                    echo "================================================"
                '''
                input message: 'Trivy found security vulnerabilities! Do you want to send the report to Groq AI for automatic fix suggestions?',
                      ok: 'Yes - Send to AI',
                      submitter: 'admin'
            }
        }

        stage('AI Suggests Fix') {
            steps {
                echo '========== Stage 5: Groq AI Analyzing Vulnerabilities =========='
                sh '''
                    echo "Reading Trivy report..."
                    SUMMARY=$(cat trivy-report.json | jq -r '
                        .Results[]? |
                        .Misconfigurations[]? |
                        "ID: " + .ID + " | Severity: " + .Severity + " | Message: " + .Message + " | Fix: " + .Resolution
                    ')

                    MAIN_TF=$(cat terraform/main.tf)

                    echo "Sending to Groq AI..."

                    cat > /tmp/prompt.json << PROMPTEOF
{
  "model": "llama-3.3-70b-versatile",
  "messages": [
    {
      "role": "system",
      "content": "You are a DevSecOps security expert. You will be given Terraform code and a list of security vulnerabilities found by Trivy scanner. Your job is to fix ALL the vulnerabilities. Return ONLY the complete fixed Terraform HCL code. No explanation, no markdown formatting, no code blocks, no backticks. Start directly with: terraform {"
    },
    {
      "role": "user",
      "content": "Fix these security vulnerabilities found by Trivy:\n\n${SUMMARY}\n\nHere is the Terraform code to fix:\n\n${MAIN_TF}\n\nReturn ONLY the fixed terraform code starting with terraform {"
    }
  ],
  "temperature": 0.1,
  "max_tokens": 4000
}
PROMPTEOF

                    RESPONSE=$(curl -s \
                        "https://api.groq.com/openai/v1/chat/completions" \
                        -H "Authorization: Bearer ${GROQ_API_KEY}" \
                        -H "Content-Type: application/json" \
                        -d @/tmp/prompt.json)

                    echo "AI Response received!"
                    API_ERROR=$(echo "$RESPONSE" | jq -r '.error.message // empty')

                    if [ ! -z "$API_ERROR" ]; then
                        echo "API Error: $API_ERROR"
                        exit 1
                    fi

                    FIXED_CODE=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // empty')

                    if [ -z "$FIXED_CODE" ]; then
                        echo "ERROR: AI returned empty response!"
                        echo "Full response: $RESPONSE"
                        exit 1
                    fi

                    echo "$FIXED_CODE" > /tmp/ai-fixed-main.tf

                    echo ""
                    echo "================================================"
                    echo "   AI SUGGESTED FIX - PLEASE REVIEW:"
                    echo "================================================"
                    cat /tmp/ai-fixed-main.tf
                    echo "================================================"
                    echo "Review the AI suggested code above"
                    echo "================================================"
                '''
            }
        }

        stage('Human Approval: Apply AI Fix?') {
            steps {
                sh '''
                    echo ""
                    echo "================================================"
                    echo "   HUMAN REVIEW REQUIRED"
                    echo "================================================"
                    echo "AI has suggested fixes for all vulnerabilities."
                    echo "The suggested code is shown above in Stage 5."
                    echo "Please review before approving."
                    echo "================================================"
                '''
                input message: 'Review the AI suggested Terraform code above. Do you approve applying these fixes?',
                      ok: 'Approve - Apply AI Fix',
                      submitter: 'admin'
            }
        }

        stage('Apply AI Fix') {
            steps {
                echo '========== Stage 7: Applying AI Fix =========='
                sh '''
                    echo "Applying AI suggested fixes to terraform/main.tf..."
                    cp /tmp/ai-fixed-main.tf terraform/main.tf
                    echo ""
                    echo "================================================"
                    echo "   FIXED CODE APPLIED:"
                    echo "================================================"
                    cat terraform/main.tf
                    echo "================================================"
                    echo "AI fixes applied successfully!"
                '''
            }
        }

        stage('Trivy Re-Scan') {
            steps {
                echo '========== Stage 8: Final Security Scan =========='
                sh '''
                    echo "Running Trivy scan on AI-fixed code..."
                    trivy config \
                        --exit-code 1 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                '''
            }
            post {
                success {
                    echo 'ZERO vulnerabilities found! AI fixes verified!'
                }
                failure {
                    echo 'Still has vulnerabilities - AI fix incomplete!'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                echo '========== Stage 9: Terraform Plan =========='
                sh '''
                    echo "================================================"
                    echo "Security scan passed!"
                    echo "Infrastructure is secure and ready to deploy!"
                    echo "================================================"
                '''
            }
        }

    }

    post {
        always {
            echo '========== Pipeline Complete =========='
        }
        success {
            echo 'PIPELINE PASSED - Secure infrastructure ready!'
        }
        failure {
            echo 'PIPELINE FAILED - Check logs above'
        }
    }
}
```

---

## The Exact Flow This Creates:
```
Stage 1: Checkout code
Stage 2: Install Trivy
Stage 3: Trivy scans → finds 5 real vulnerabilities
Stage 4: ⏸️ PAUSES → shows vulnerability list
         → YOU click "Yes - Send to AI"
Stage 5: Jenkins calls Groq API with ACTUAL report
         → Groq reads real vulnerabilities
         → Groq generates REAL fix dynamically
         → Shows AI suggested code in console
Stage 6: ⏸️ PAUSES → "Review AI fix above"
         → YOU click "Approve - Apply AI Fix"
Stage 7: Applies AI fix to main.tf
Stage 8: Trivy re-scans → 0 vulnerabilities ✅
Stage 9: Terraform Plan ✅
