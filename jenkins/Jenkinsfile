pipeline {
    agent any

    environment {
        GROQ_API_KEY = credentials('groq-api-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Stage 1: Pulling Code from GitHub =========='
                git credentialsId: 'github-credentials',
                    url: 'https://github.com/CoderSanku/DevSecOps-Assignment.git',
                    branch: 'main'
            }
        }

        stage('Install Tools') {
            steps {
                echo '========== Stage 2: Installing Trivy =========='
                sh '''
                    apt-get update -y -qq
                    apt-get install -y wget apt-transport-https gnupg python3
                    wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor > /usr/share/keyrings/trivy.gpg
                    echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" > /etc/apt/sources.list.d/trivy.list
                    apt-get update -qq
                    apt-get install -y trivy
                    trivy --version
                '''
            }
        }

        stage('Trivy IaC Scan') {
            steps {
                echo '========== Stage 3: Scanning Terraform for Vulnerabilities =========='
                sh '''
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format json \
                        --output trivy-report.json \
                        ./terraform

                    echo "================================================================"
                    echo "           SECURITY VULNERABILITY REPORT"
                    echo "================================================================"
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================================"
                '''
            }
        }

        stage('Human Approval: Send to AI?') {
            steps {
                echo '========== Stage 4: Waiting for Human Review =========='
                echo 'Review the vulnerability report in Stage 3 above.'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Vulnerabilities found. Send to Groq AI for fix?', ok: 'Yes, Send to AI'
                }
            }
        }

        stage('AI Security Remediation') {
            steps {
                echo '========== Stage 5: Groq AI Fixing Vulnerabilities =========='
                sh '''
                    cat > /tmp/fix.py << 'PYEOF'
import subprocess, json, urllib.request, os

result = subprocess.run(
    ['jq', '-r', '.Results[]? | .Misconfigurations[]? | "ID: " + .ID + " | Severity: " + .Severity + " | Fix: " + .Resolution'],
    stdin=open('trivy-report.json'),
    capture_output=True, text=True
)
summary = result.stdout.strip()
print('Vulnerabilities found:')
print(summary)

main_tf = open('terraform/main.tf').read()
user_msg = "Fix these vulnerabilities:\\n\\n" + summary + "\\n\\nCode:\\n\\n" + main_tf + "\\n\\nReturn ONLY fixed terraform code."

payload = json.dumps({
    "model": "llama-3.3-70b-versatile",
    "messages": [
        {
            "role": "system",
            "content": "You are a DevSecOps expert. Return ONLY fixed Terraform HCL code. No explanation, no markdown, no backticks. Start with: terraform {"
        },
        {
            "role": "user",
            "content": user_msg
        }
    ],
    "temperature": 0.1,
    "max_tokens": 4000
}).encode('utf-8')

api_key = open('/tmp/groq_key.txt').read().strip()
print('API key loaded, length: ' + str(len(api_key)))

req = urllib.request.Request(
    'https://api.groq.com/openai/v1/chat/completions',
    data=payload,
    headers={
        'Authorization': 'Bearer ' + api_key,
        'Content-Type': 'application/json',
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
    }
)

print('Calling Groq API...')
try:
    with urllib.request.urlopen(req, timeout=60) as response:
        result = json.loads(response.read().decode('utf-8'))
except urllib.error.HTTPError as e:
    error_body = e.read().decode('utf-8')
    print('HTTP Error: ' + str(e.code))
    print('Error body: ' + error_body)
    raise
    
fixed_code = result['choices'][0]['message']['content']
print('AI fix received!')

with open('/tmp/ai_fixed_main.tf', 'w') as f:
    f.write(fixed_code)

print('================================================================')
print('           AI FIXED TERRAFORM CODE')
print('================================================================')
print(fixed_code)
print('================================================================')
PYEOF

                    echo "${GROQ_API_KEY}" > /tmp/groq_key.txt
                    python3 /tmp/fix.py
                    rm -f /tmp/groq_key.txt
                '''
            }
        }

        stage('Human Approval: Apply Fix?') {
            steps {
                echo '========== Stage 6: Review AI Fix =========='
                echo 'Review the AI fixed code printed in Stage 5 above.'
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Apply AI fixes to terraform/main.tf?', ok: 'Yes, Apply Fix'
                }
                sh '''
                    cp terraform/main.tf terraform/main.tf.backup
                    cp /tmp/ai_fixed_main.tf terraform/main.tf
                    echo "AI fix applied to terraform/main.tf!"
                    echo "Backup saved to terraform/main.tf.backup"
                '''
            }
        }

        stage('Trivy Re-Scan') {
            steps {
                echo '========== Stage 7: Re-scanning After AI Fix =========='
                sh '''
                    echo "================================================================"
                    echo "           POST-FIX SECURITY SCAN RESULTS"
                    echo "================================================================"
                    trivy config \
                        --exit-code 1 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================================"
                '''
            }
            post {
                success { echo 'SUCCESS: Zero HIGH/CRITICAL vulnerabilities!' }
                failure { echo 'WARNING: Vulnerabilities still remain!' }
            }
        }

        stage('Push Fixed Code to GitHub') {
            steps {
                echo '========== Stage 8: Pushing Fixed Code to GitHub =========='
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                        git config user.email "jenkins@devsecops.com"
                        git config user.name "Jenkins AI Bot"
                        git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@github.com/CoderSanku/DevSecOps-Assignment.git
                        git add terraform/main.tf
                        git commit -m "AI Security Fix: Resolved 5 Terraform vulnerabilities via Groq AI"
                        git push origin main
                        echo "Fixed code pushed to GitHub successfully!"
                    '''
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                echo '========== Stage 9: Terraform Plan =========='
                echo 'All security checks passed!'
                echo 'Fixed code pushed to GitHub!'
                echo 'Ready for terraform apply with secure infrastructure.'
            }
        }

    }

    post {
        always  { echo '========== Pipeline Complete ==========' }
        failure { echo 'Pipeline FAILED - Review the failing stage above.' }
        success { echo 'Pipeline PASSED - Secure code pushed to GitHub!' }
    }
}


