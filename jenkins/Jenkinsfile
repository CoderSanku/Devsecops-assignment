pipeline {
    agent any

    environment {
        GROQ_API_KEY = credentials('groq-api-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Stage 1: Pulling Code from GitHub =========='
                checkout scm
            }
        }

        stage('Install Trivy') {
            steps {
                echo '========== Stage 2: Installing Trivy Scanner =========='
                sh '''
                    apt-get update -y -qq
                    apt-get install -y wget curl jq apt-transport-https gnupg dos2unix -qq
                    wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor > /usr/share/keyrings/trivy.gpg
                    echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" > /etc/apt/sources.list.d/trivy.list
                    apt-get update -qq
                    apt-get install -y trivy
                    trivy --version
                '''
            }
        }

        stage('Trivy IaC Scan') {
            steps {
                echo '========== Stage 3: Scanning Terraform for Vulnerabilities =========='
                sh '''
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format json \
                        --output trivy-report.json \
                        ./terraform

                    echo ""
                    echo "================================================"
                    echo "         TRIVY SECURITY SCAN REPORT"
                    echo "================================================"
                    trivy config \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                    echo "================================================"

                    VULN_COUNT=$(cat trivy-report.json | jq '[.Results[]?.Misconfigurations[]?] | length')
                    echo "Total vulnerabilities found: $VULN_COUNT"
                    echo "================================================"
                    echo $VULN_COUNT > /tmp/vuln_count.txt
                '''
            }
        }

        stage('Security Gate') {
            steps {
                script {
                    def vulnCount = sh(script: 'cat /tmp/vuln_count.txt', returnStdout: true).trim().toInteger()

                    if (vulnCount == 0) {
                        echo '================================================'
                        echo 'ZERO vulnerabilities found! Code is already secure!'
                        echo 'Skipping AI fix stages - proceeding to deploy!'
                        echo '================================================'
                        env.NEEDS_FIX = 'false'
                    } else {
                        echo '================================================'
                        echo "Found ${vulnCount} vulnerabilities - proceeding to AI fix!"
                        echo '================================================'
                        env.NEEDS_FIX = 'true'
                    }
                }
            }
        }

        stage('Human Approval: Send to AI?') {
            when {
                environment name: 'NEEDS_FIX', value: 'true'
            }
            steps {
                sh '''
                    echo ""
                    echo "================================================"
                    echo "   SECURITY VULNERABILITIES DETECTED"
                    echo "================================================"
                    cat trivy-report.json | jq -r '.Results[]? | .Misconfigurations[]? | "  ID: " + .ID + " [" + .Severity + "] - " + .Message'
                    echo "================================================"
                    echo "Waiting for human approval to send to AI..."
                    echo "================================================"
                '''
                input message: 'Trivy found security vulnerabilities! Send report to Groq AI for fix suggestions?',
                      ok: 'Yes - Send to AI',
                      submitter: 'admin'
            }
        }

        stage('AI Suggests Fix') {
            when {
                environment name: 'NEEDS_FIX', value: 'true'
            }
            steps {
                echo '========== Stage 6: Groq AI Analyzing and Fixing =========='
                withCredentials([string(credentialsId: 'groq-api-key', variable: 'GROQ_KEY')]) {
                    sh '''
                        cat trivy-report.json | jq -r '
                            .Results[]? |
                            .Misconfigurations[]? |
                            "ID: " + .ID + " | Severity: " + .Severity + " | Fix: " + .Resolution
                        ' > /tmp/summary.txt

                        dos2unix terraform/main.tf 2>/dev/null
                        cat terraform/main.tf > /tmp/maintf.txt

                        echo "Vulnerabilities being sent to AI:"
                        cat /tmp/summary.txt

                        jq -n \
                            --arg summary "$(cat /tmp/summary.txt)" \
                            --arg code "$(cat /tmp/maintf.txt)" \
                            '{
                                "model": "llama-3.3-70b-versatile",
                                "messages": [
                                    {
                                        "role": "system",
                                        "content": "You are a DevSecOps expert. Fix ALL Terraform vulnerabilities listed. Return ONLY raw HCL terraform code. No markdown, no backticks, no explanation. Start directly with: terraform {"
                                    },
                                    {
                                        "role": "user",
                                        "content": ("Fix these vulnerabilities:\n\n" + $summary + "\n\nTerraform code to fix:\n\n" + $code + "\n\nReturn ONLY the fixed terraform code.")
                                    }
                                ],
                                "temperature": 0.1,
                                "max_tokens": 4000
                            }' > /tmp/prompt.json

                        echo "Calling Groq API..."

                        curl -s \
                            --max-time 60 \
                            --header "Authorization: Bearer $GROQ_KEY" \
                            --header "Content-Type: application/json" \
                            --data @/tmp/prompt.json \
                            "https://api.groq.com/openai/v1/chat/completions" \
                            --output /tmp/response.json

                        echo "Response size: $(wc -c < /tmp/response.json) bytes"

                        API_ERROR=$(jq -r '.error.message // empty' /tmp/response.json)
                        if [ ! -z "$API_ERROR" ]; then
                            echo "API Error: $API_ERROR"
                            exit 1
                        fi

                        jq -r '.choices[0].message.content // empty' /tmp/response.json > /tmp/ai-fixed-main.tf

                        if [ ! -s /tmp/ai-fixed-main.tf ]; then
                            echo "ERROR: AI returned empty response!"
                            exit 1
                        fi

                        echo ""
                        echo "================================================"
                        echo "   AI SUGGESTED FIX - PLEASE REVIEW:"
                        echo "================================================"
                        cat /tmp/ai-fixed-main.tf
                        echo "================================================"
                    '''
                }
            }
        }

        stage('Human Approval: Apply AI Fix?') {
            when {
                environment name: 'NEEDS_FIX', value: 'true'
            }
            steps {
                sh '''
                    echo ""
                    echo "================================================"
                    echo "   HUMAN REVIEW REQUIRED"
                    echo "================================================"
                    echo "AI suggested fix is shown above in Stage 6 logs"
                    echo "Review the code before approving"
                    echo "================================================"
                '''
                input message: 'Review the AI suggested fix shown above. Do you approve applying these fixes?',
                      ok: 'Approve - Apply Fix',
                      submitter: 'admin'
            }
        }

        stage('Apply AI Fix') {
            when {
                environment name: 'NEEDS_FIX', value: 'true'
            }
            steps {
                echo '========== Stage 8: Applying AI Fix =========='
                sh '''
                    cp /tmp/ai-fixed-main.tf terraform/main.tf
                    echo "AI fixes applied successfully!"
                    cat terraform/main.tf
                '''
            }
        }

        stage('Trivy Re-Scan') {
            when {
                environment name: 'NEEDS_FIX', value: 'true'
            }
            steps {
                echo '========== Stage 9: Final Security Scan =========='
                sh '''
                    trivy config \
                        --exit-code 1 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ./terraform
                '''
            }
            post {
                success {
                    echo 'ZERO vulnerabilities! AI fixes verified successfully!'
                }
                failure {
                    echo 'Still has vulnerabilities - review AI fix!'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                echo '========== Stage 10: Terraform Plan =========='
                sh '''
                    echo "================================================"
                    echo "Security scan passed!"
                    echo "Infrastructure is secure and ready to deploy!"
                    echo "================================================"
                '''
            }
        }

    }

    post {
        always {
            echo '========== Pipeline Complete =========='
        }
        success {
            echo 'PIPELINE PASSED - Secure infrastructure ready!'
        }
        failure {
            echo 'PIPELINE FAILED - Check logs above'
        }
    }
}
```

---

## What Changed

Added a **Security Gate** stage that sets `NEEDS_FIX=true` or `NEEDS_FIX=false`. All AI stages use `when { environment name: 'NEEDS_FIX', value: 'true' }` — much more reliable than the previous `when expression` approach.

**Two scenarios now:**
```
Vulnerable code  → Gate sets NEEDS_FIX=true  → AI stages run ✅
Clean code       → Gate sets NEEDS_FIX=false → AI stages skipped ✅
